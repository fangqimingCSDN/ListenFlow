# ============================================================
# 环境变量配置示例 - 复制为 .env 并填写实际值
# ============================================================

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:tarena@localhost:5432/speech_db

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_AUDIO=speech-audio
MINIO_BUCKET_TEXT=speech-text
MINIO_SECURE=false

# ── Qwen3-ASR 配置 (ASR_BACKEND=qwen3 时生效) ──────────────────────────────
# ModelScope 模型ID（国内镜像，自动下载，无需 HF token）
QWEN3_ASR_MODEL_ID=Qwen/Qwen3-ASR-1.7B
# 本地模型路径（已手动下载则填此路径，留空=自动下载）
QWEN3_ASR_MODEL_PATH=
# system prompt，控制输出语言/格式/专业术语风格
QWEN3_ASR_SYSTEM_PROMPT=Transcribe the speech into Simplified Chinese text with punctuation.

# ── ASR 后端选择 ─────────────────────────────────────────────
# funasr   : FunASR paraformer-zh (默认，中文最优，速度快，无需HF token)
# whisper  : faster-whisper large-v3 (多语言强，精度高，需更大显存)
ASR_BACKEND=funasr

# 最大并发 ASR 转写数 (GPU 建议 1~2 防显存溢出; CPU 可设 4)
ASR_MAX_CONCURRENT=4

# faster-whisper 参数 (ASR_BACKEND=whisper 时生效)
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=auto
# GPU: float16 | CPU: int8
WHISPER_COMPUTE_TYPE=float16
# 本地模型路径（留空则自动下载到 ~/.cache）
WHISPER_MODEL_PATH=

# HuggingFace Token（pyannote 模型需要，ERes2Net 不需要）
HUGGINGFACE_TOKEN=

# ── VAD 断句配置 ─────────────────────────────────────────────
# 说话人停顿超过此时间(毫秒)则断句（建议 600~1200）
VAD_SILENCE_DURATION_MS=400
# 单段最大时长(秒)，超过强制截断（防止长时间不停顿卡死）
VAD_MAX_SEGMENT_DURATION=8
# VAD 语音概率阈值（0~1，越高越严格）
VAD_THRESHOLD=0.5

# ── 向量数据库（可选）───────────────────────────────────────
# 是否启用语义向量存储（支持跨会话语义搜索）
ENABLE_VECTOR_STORE=false

# 向量库选择: milvus (推荐) | qdrant (轻量备选)
VECTOR_BACKEND=milvus

# Milvus 连接（推荐：生产级，支持十亿级向量，HNSW索引）
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Qdrant 连接（备选：轻量单机部署）
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/speech_proj.log

# ── CORS ────────────────────────────────────────────────────
# JSON 数组格式
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174","http://localhost:8080","http://127.0.0.1:3000","http://127.0.0.1:5173"]
